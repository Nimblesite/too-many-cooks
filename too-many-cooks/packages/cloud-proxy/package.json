{
  "name": "@too-many-cooks/cloud-proxy",
  "version": "0.5.0",
  "description": "E2E encrypted stdio MCP proxy for Too Many Cooks Cloud",
  "type": "module",
  "main": "build/src/index.js",
  "types": "build/src/index.d.ts",
  "bin": {
    "tmc-cloud-proxy": "build/bin/proxy.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node build/bin/proxy.js",
    "test": "node --import tsx --test --test-concurrency=1 --test-reporter=spec --test-reporter-destination=stdout --test-reporter=../../../../bail-reporter.mjs --test-reporter-destination=stderr test/*.ts",
    "test:coverage": "c8 --reporter=text --reporter=lcov --reports-dir=coverage --src=src node --import tsx --test --test-concurrency=1 --test-reporter=spec --test-reporter-destination=stdout --test-reporter=../../../../bail-reporter.mjs --test-reporter-destination=stderr test/*.ts"
  },
  "dependencies": {
    "@too-many-cooks/core": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "c8": "^11.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
