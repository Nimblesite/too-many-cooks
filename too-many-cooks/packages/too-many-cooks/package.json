{
  "name": "@too-many-cooks/local",
  "version": "0.5.0",
  "description": "Too Many Cooks MCP server — SQLite (local) or encrypted cloud backend",
  "type": "module",
  "main": "build/src/index.js",
  "types": "build/src/index.d.ts",
  "bin": {
    "too-many-cooks": "build/bin/server.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node build/bin/server.js",
    "test": "node --import tsx --test --test-concurrency=1 --test-reporter=spec --test-reporter-destination=stdout --test-reporter=../../../bail-reporter.mjs --test-reporter-destination=stderr test/*.ts",
    "test:coverage": "c8 --reporter=text --reporter=html --reporter=lcov --reports-dir=coverage --src=src node --import tsx --test --test-concurrency=1 --test-reporter=spec --test-reporter-destination=stdout --test-reporter=../../../bail-reporter.mjs --test-reporter-destination=stderr test/*.ts"
  },
  "dependencies": {
    "@too-many-cooks/core": "*",
    "better-sqlite3": "^12.5.0"
  },
  "devDependencies": {
    "@prisma/client": "^7.5.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "c8": "^11.0.0",
    "prisma": "^7.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
