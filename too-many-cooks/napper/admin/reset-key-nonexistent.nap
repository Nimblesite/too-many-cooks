[meta]
name = Reset Key Nonexistent
description = Attempt to reset key for an agent that does not exist

[vars]
baseUrl = http://localhost:4040

[request]
method = POST
url = {{baseUrl}}/admin/reset-key

[request.headers]
Content-Type = application/json

[request.body]
"""
{
  "agentName": "ghost-agent"
}
"""

[assert]
status = 400
