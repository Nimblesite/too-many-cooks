[meta]
name = Delete Agent Nonexistent
description = Attempt to delete an agent that does not exist

[vars]
baseUrl = http://localhost:4040

[request]
method = POST
url = {{baseUrl}}/admin/delete-agent

[request.headers]
Content-Type = application/json

[request.body]
"""
{
  "agentName": "ghost-agent"
}
"""

[assert]
status = 400
