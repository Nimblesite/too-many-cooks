[meta]
name = Delete Agent Missing Name
description = Verify 400 when agentName is missing from delete-agent

[vars]
baseUrl = http://localhost:4040

[request]
method = POST
url = {{baseUrl}}/admin/delete-agent

[request.headers]
Content-Type = application/json

[request.body]
"""
{}
"""

[assert]
status = 400
