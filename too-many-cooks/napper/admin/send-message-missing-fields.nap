[meta]
name = Send Message Missing Fields
description = Verify 400 when required fields are missing

[vars]
baseUrl = http://localhost:4040

[request]
method = POST
url = {{baseUrl}}/admin/send-message

[request.headers]
Content-Type = application/json

[request.body]
"""
{
  "fromAgent": "admin"
}
"""

[assert]
status = 400
