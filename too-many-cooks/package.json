{
  "name": "too-many-cooks",
  "version": "0.5.0",
  "description": "Multi-agent Git coordination MCP server - enables multiple AI agents to safely edit a git repository simultaneously with file locking, messaging, and plan visibility",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/core && npm run build -w packages/local",
    "start": "node packages/local/build/bin/server.js",
    "lint": "eslint .",
    "test": "npm run build -w packages/core && npm test -w packages/local",
    "test:local": "npm test -w packages/local"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "multi-agent",
    "typescript"
  ],
  "author": "Christian Findlay",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MelbourneDeveloper/dart_node.git"
  },
  "bugs": {
    "url": "https://github.com/MelbourneDeveloper/dart_node/issues"
  },
  "homepage": "https://github.com/MelbourneDeveloper/dart_node/tree/main/examples/too-many-cooks#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1"
  }
}
